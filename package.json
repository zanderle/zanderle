{
  "private": true,
  "scripts": {
    "build": "npm run webpack:build && npx @11ty/eleventy",
    "start": "npm-run-all webpack:build --parallel webpack:watch eleventy:serve",
    "eleventy:serve": "npx @11ty/eleventy --serve",
    "webpack:build": "webpack --mode production --config webpack/webpack.config.js",
    "webpack:watch": "webpack --watch --mode development --config webpack/webpack.config.js"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@11ty/eleventy-img": "^5.0.0",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.0",
    "babel-loader": "^9.1.3",
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "css-loader": "^7.1.2",
    "css-minimizer-webpack-plugin": "^7.0.0",
    "mini-css-extract-plugin": "^2.9.0",
    "sass": "^1.77.0",
    "sass-loader": "^16.0.0",
    "npm-run-all": "^4.1.5",
    "webpack": "^5.94.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "d3": "^3.5.17"
  }
}
